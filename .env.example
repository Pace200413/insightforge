# --- Application ---
APP_ENV=development
APP_NAME=InsightForge
LOG_LEVEL=INFO

# --- Database (matches docker-compose.yml) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=insightforge
POSTGRES_USER=insightforge
POSTGRES_PASSWORD=insightforge_dev_password

# --- LLM provider ---
# Get a key from https://console.anthropic.com (or set OPENAI_API_KEY if you swap providers)
ANTHROPIC_API_KEY=

# --- Safety limits (used by the SQL firewall in later stages) ---
QUERY_TIMEOUT_SECONDS=15
QUERY_MAX_ROWS=10000
QUERY_MAX_REPAIR_ATTEMPTS=3
